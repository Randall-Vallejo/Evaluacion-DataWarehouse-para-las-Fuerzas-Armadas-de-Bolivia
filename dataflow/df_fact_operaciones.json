{
	"name": "df_fact_operaciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sink_operaciones_silver",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_fact_operacion",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as integer,",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as integer,",
				"          incidentes as integer,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> source1",
				"source1 select(mapColumn(",
				"          id_operacion,",
				"          id_tipo,",
				"          id_unidad_resp,",
				"          id_zona,",
				"          fecha_inicio",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(!isNull(id_operacion)",
				"&& !isNull(fecha_inicio)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}